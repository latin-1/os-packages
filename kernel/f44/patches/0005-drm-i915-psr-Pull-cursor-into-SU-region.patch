From 9eb3b13d6bdb7cf19d37094934180d0e9dc6aa3b Mon Sep 17 00:00:00 2001
From: Arun R Murthy <arun.r.murthy@intel.com>
Date: Thu, 9 Jul 2026 10:44:57 +0530
Subject: [PATCH 5/5] drm/i915/psr: Pull cursor into SU region

With SU early transport as part of the WA 16021516641, X POSt is set to
'0'. User might see the cursor pulled towards the left on the display.
So pull the cusrsor within the SU region to bypass the WA.

Signed-off-by: Arun R Murthy <arun.r.murthy@intel.com>
---
 drivers/gpu/drm/i915/display/intel_psr.c | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/drivers/gpu/drm/i915/display/intel_psr.c b/drivers/gpu/drm/i915/display/intel_psr.c
index 598fe769a402..c23eb240b60a 100644
--- a/drivers/gpu/drm/i915/display/intel_psr.c
+++ b/drivers/gpu/drm/i915/display/intel_psr.c
@@ -2788,7 +2788,6 @@ intel_psr2_sel_fetch_et_alignment(struct intel_atomic_state *state,
 		return;
 
 	for_each_new_intel_plane_in_state(state, plane, new_plane_state, i) {
-		struct drm_rect inter;
 
 		if (new_plane_state->hw.crtc != crtc_state->uapi.crtc)
 			continue;
@@ -2799,10 +2798,6 @@ intel_psr2_sel_fetch_et_alignment(struct intel_atomic_state *state,
 		if (!new_plane_state->uapi.visible)
 			continue;
 
-		inter = crtc_state->psr2_su_area;
-		if (!drm_rect_intersect(&inter, &new_plane_state->uapi.dst))
-			continue;
-
 		clip_area_update(&crtc_state->psr2_su_area, &new_plane_state->uapi.dst,
 				 display_area);
 		*cursor_in_su_area = true;
-- 
